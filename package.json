{
  "name": "jira-auto-update",
  "version": "1.0.0",
  "description": "Commit-triggered Jira auto-update hook system",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/setup-hooks.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "setup-hooks": "node scripts/setup-hooks.js",
    "branch": "bash scripts/create-branch.sh"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fast-check": "^3.23.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
